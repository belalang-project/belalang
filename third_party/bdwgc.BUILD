load("@rules_cc//cc:defs.bzl", "cc_library")

cc_library(
    name = "bdwgc",
    srcs = [
        "allchblk.c",
        "alloc.c",
        "blacklst.c",
        "dbg_mlc.c",
        "dyn_load.c",
        "finalize.c",
        "headers.c",
        "mach_dep.c",
        "malloc.c",
        "mallocx.c",
        "mark.c",
        "mark_rts.c",
        "misc.c",
        "new_hblk.c",
        "obj_map.c",
        "os_dep.c",
        "ptr_chck.c",
        "reclaim.c",
        "typd_mlc.c",
        "gc_dlopen.c",
        "pthread_start.c",
        "pthread_support.c",
        "pthread_stop_world.c",
    ],
    hdrs = glob(["include/**/*.h"]),
    includes = ["include"],
    copts = [
        "-DALL_INTERIOR_POINTERS",
        "-DNO_EXECUTE_PERMISSION",
        "-DGC_BUILTIN_ATOMIC",
        "-DGC_THREADS",
        "-D_REENTRANT",
    ],
    linkopts = [
        "-lpthread",
        "-ldl",
    ],
    visibility = ["//visibility:public"],
)
