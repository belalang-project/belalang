# RUN: %belalang build --emit=llvm %s | %FileCheck %s

# CHECK: declare void @brt_mmtk_init()
# CHECK: declare ptr @brt_mmtk_alloc(i64)
# CHECK: declare void @brt_print_int(i64)

# CHECK:      define i64 @fn.main.anon(i64 %[[ARG0:.*]], i64 %[[ARG1:.*]]) {
# CHECK-NEXT:   %[[V0:.*]] = call ptr @brt_mmtk_alloc(i64 8)
# CHECK-NEXT:   store i64 %[[ARG0]], ptr %[[V0]], align 4
# CHECK-NEXT:   %[[V1:.*]] = call ptr @brt_mmtk_alloc(i64 8)
# CHECK-NEXT:   store i64 %[[ARG1]], ptr %[[V1]], align 4
# CHECK-NEXT:   %[[V2:.*]] = load i64, ptr %[[V0]], align 4
# CHECK-NEXT:   %[[V3:.*]] = load i64, ptr %[[V1]], align 4
# CHECK-NEXT:   %[[V4:.*]] = add i64 %[[V2]], %[[V3]]
# CHECK-NEXT:   ret i64 %[[V4]]
# CHECK-NEXT: }

# CHECK:      define i64 @main() {
# CHECK-NEXT:   call void @brt_mmtk_init()
# CHECK-NEXT:   %[[V5:.*]] = call ptr @brt_mmtk_alloc(i64 8)
# CHECK-NEXT:   store ptr @fn.main.anon, ptr %[[V5]], align 8
# CHECK-NEXT:   %[[V6:.*]] = load ptr, ptr %[[V5]], align 8
# CHECK-NEXT:   %[[V7:.*]] = call i64 %[[V6]](i64 2, i64 3)
# CHECK-NEXT:   %[[V8:.*]] = call ptr @brt_mmtk_alloc(i64 8)
# CHECK-NEXT:   store i64 %[[V7]], ptr %[[V8]], align 4
# CHECK-NEXT:   %[[V9:.*]] = load i64, ptr %[[V8]], align 4
# CHECK-NEXT:   call void @brt_print_int(i64 %[[V9]])
# CHECK-NEXT:   ret i64 0
# CHECK-NEXT: }

add := fn(x: Int, y: Int): Int { return x + y }
p := add(2, 3)
print(p)
