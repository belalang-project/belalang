# RUN: %belalang --emit ast %s | %FileCheck %s
a * b + c;
!-a;
a + b + c;
a + b - c;
a * b * c;
a * b / c;
a + b / c;
a + b * c + d / e - f;
3 + 4; -5 * 5;
5 > 4 == 3 < 4;
5 < 4 != 3 > 4;
3 + 4 * 5 == 3 * 1 + 4 * 5;
3 + 4 * 5 == 3 * 1 + 4 * 5;
3 > 5 == false;
3 < 5 == true;
1 + (2 + 3) + 4;
(5 + 5) * 2;
2 / (5 + 5);
-(5 + 5);
!(true == true);
a + add(b * c) + d;
add(a, b, 1, 2 * 3, 4 + 5, add(6, 7 * 8));
add(a + b + c * d / f + g);

