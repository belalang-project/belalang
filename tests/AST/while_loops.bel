# RUN: %belalang build --emit ast %s | %FileCheck %s
i := 0;
while i < 10 {
  i = i + 1;
}

# CHECK:      Program
# CHECK-NEXT:   ExpressionStatement
# CHECK-NEXT:     VarExpression(ColonAssign)
# CHECK-NEXT:       Identifier(i)
# CHECK-NEXT:       Integer(0)
# CHECK-NEXT:   WhileStatement
# CHECK-NEXT:     InfixExpression(Lt)
# CHECK-NEXT:       Identifier(i)
# CHECK-NEXT:       Integer(10)
# CHECK-NEXT:     BlockExpression
# CHECK-NEXT:       ExpressionStatement
# CHECK-NEXT:         VarExpression(Assign)
# CHECK-NEXT:           Identifier(i)
# CHECK-NEXT:           InfixExpression(Add)
# CHECK-NEXT:             Identifier(i)
# CHECK-NEXT:             Integer(1)
