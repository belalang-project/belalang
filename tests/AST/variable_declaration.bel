# RUN: %belalang build --emit ast %s | %FileCheck %s

x: Int
x: String

# CHECK:      Program
# CHECK-NEXT:   ExpressionStatement
# CHECK-NEXT:     VarDeclExpression(Some(Integer))
# CHECK-NEXT:       Identifier(x)
# CHECK-NEXT:   ExpressionStatement
# CHECK-NEXT:     VarDeclExpression(Some(String))
# CHECK-NEXT:       Identifier(x)
