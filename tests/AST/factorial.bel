# RUN: %belalang build --emit ast %s | %FileCheck %s
fact := fn(n) {
  if (n < 2) {
    return 1;
  }
  
  return n * fact(n - 1);
};

# CHECK:      Program
# CHECK-NEXT:   ExpressionStatement
# CHECK-NEXT:     VarDeclExpression(None)
# CHECK-NEXT:       Identifier(fact)
# CHECK-NEXT:       FunctionLiteral
# CHECK-NEXT:         Identifier(n)
# CHECK-NEXT:         BlockExpression
# CHECK-NEXT:           ExpressionStatement
# CHECK-NEXT:             IfExpression
# CHECK-NEXT:               InfixExpression(Lt)
# CHECK-NEXT:                 Identifier(n)
# CHECK-NEXT:                 Integer(2)
# CHECK-NEXT:               BlockExpression
# CHECK-NEXT:                 ReturnStatement
# CHECK-NEXT:                   Integer(1)
# CHECK-NEXT:           ReturnStatement
# CHECK-NEXT:             InfixExpression(Mul)
# CHECK-NEXT:               Identifier(n)
# CHECK-NEXT:               CallExpression
# CHECK-NEXT:                 Identifier(fact)
# CHECK-NEXT:                 InfixExpression(Sub)
# CHECK-NEXT:                   Identifier(n)
# CHECK-NEXT:                   Integer(1)
