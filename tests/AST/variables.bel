# RUN: %belalang --emit ast %s | %FileCheck %s
int_var := 123;
flo_var := 44.2;
str_var := "Hello, World!";

int_var = 1;
flo_var = 1.4;
str_var = "Hello, Mom!";

# CHECK:      Program
# CHECK-NEXT:   ExpressionStatement
# CHECK-NEXT:     VarExpression(ColonAssign)
# CHECK-NEXT:       Identifier(int_var)
# CHECK-NEXT:       Integer(123)
# CHECK-NEXT:   ExpressionStatement
# CHECK-NEXT:     VarExpression(ColonAssign)
# CHECK-NEXT:       Identifier(flo_var)
# CHECK-NEXT:       Float(44.2)
# CHECK-NEXT:   ExpressionStatement
# CHECK-NEXT:     VarExpression(ColonAssign)
# CHECK-NEXT:       Identifier(str_var)
# CHECK-NEXT:       String("Hello, World!")
# CHECK-NEXT:   ExpressionStatement
# CHECK-NEXT:     VarExpression(Assign)
# CHECK-NEXT:       Identifier(int_var)
# CHECK-NEXT:       Integer(1)
# CHECK-NEXT:   ExpressionStatement
# CHECK-NEXT:     VarExpression(Assign)
# CHECK-NEXT:       Identifier(flo_var)
# CHECK-NEXT:       Float(1.4)
# CHECK-NEXT:   ExpressionStatement
# CHECK-NEXT:     VarExpression(Assign)
# CHECK-NEXT:       Identifier(str_var)
# CHECK-NEXT:       String("Hello, Mom!")
