# RUN: %belalang build --emit ast %s | %FileCheck %s
int_var := 123;
flo_var := 44.2;
str_var := "Hello, World!";

int_var = 1;
flo_var = 1.4;
str_var = "Hello, Mom!";

explicit_ty: Int = 12
implicit_ty := 12

# CHECK:      Program
# CHECK-NEXT:   VarDeclStatement(None)
# CHECK-NEXT:     Identifier(int_var)
# CHECK-NEXT:     Integer(123)
# CHECK-NEXT:   VarDeclStatement(None)
# CHECK-NEXT:     Identifier(flo_var)
# CHECK-NEXT:     Float(44.2)
# CHECK-NEXT:   VarDeclStatement(None)
# CHECK-NEXT:     Identifier(str_var)
# CHECK-NEXT:     String("Hello, World!")
# CHECK-NEXT:   ExpressionStatement
# CHECK-NEXT:     VarExpression(Assign)
# CHECK-NEXT:       Identifier(int_var)
# CHECK-NEXT:       Integer(1)
# CHECK-NEXT:   ExpressionStatement
# CHECK-NEXT:     VarExpression(Assign)
# CHECK-NEXT:       Identifier(flo_var)
# CHECK-NEXT:       Float(1.4)
# CHECK-NEXT:   ExpressionStatement
# CHECK-NEXT:     VarExpression(Assign)
# CHECK-NEXT:       Identifier(str_var)
# CHECK-NEXT:       String("Hello, Mom!")
# CHECK-NEXT:   VarDeclStatement(Some(Integer))
# CHECK-NEXT:     Identifier(explicit_ty)
# CHECK-NEXT:     Integer(12)
# CHECK-NEXT:   VarDeclStatement(None)
# CHECK-NEXT:     Identifier(implicit_ty)
# CHECK-NEXT:     Integer(12)
