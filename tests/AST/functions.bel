# RUN: %belalang build --emit ast %s | %FileCheck %s
add := fn(x: Int, y: Int) {
    return x + y;
};

mul := fn(x: Int, y: Int) { x * y };

sub := fn(x: Int, y: Int): Int {
    return x - y
}

v := fn() {
  return
}

# CHECK:      Program
# CHECK-NEXT:   VarDeclStatement(None)
# CHECK-NEXT:     Identifier(add)
# CHECK-NEXT:     FunctionLiteral(None)
# CHECK-NEXT:       VarDeclStatement(Some("Int"))
# CHECK-NEXT:         Identifier(x)
# CHECK-NEXT:       VarDeclStatement(Some("Int"))
# CHECK-NEXT:         Identifier(y)
# CHECK-NEXT:       BlockExpression
# CHECK-NEXT:         ReturnStatement
# CHECK-NEXT:           InfixExpression(Add)
# CHECK-NEXT:             Identifier(x)
# CHECK-NEXT:             Identifier(y)
# CHECK-NEXT:   VarDeclStatement(None)
# CHECK-NEXT:     Identifier(mul)
# CHECK-NEXT:     FunctionLiteral(None)
# CHECK-NEXT:       VarDeclStatement(Some("Int"))
# CHECK-NEXT:         Identifier(x)
# CHECK-NEXT:       VarDeclStatement(Some("Int"))
# CHECK-NEXT:         Identifier(y)
# CHECK-NEXT:       BlockExpression
# CHECK-NEXT:         ExpressionStatement
# CHECK-NEXT:           InfixExpression(Mul)
# CHECK-NEXT:             Identifier(x)
# CHECK-NEXT:             Identifier(y)
# CHECK-NEXT:   VarDeclStatement(None)
# CHECK-NEXT:     Identifier(sub)
# CHECK-NEXT:     FunctionLiteral(Some("Int"))
# CHECK-NEXT:       VarDeclStatement(Some("Int"))
# CHECK-NEXT:         Identifier(x)
# CHECK-NEXT:       VarDeclStatement(Some("Int"))
# CHECK-NEXT:         Identifier(y)
# CHECK-NEXT:       BlockExpression
# CHECK-NEXT:         ReturnStatement
# CHECK-NEXT:           InfixExpression(Sub)
# CHECK-NEXT:             Identifier(x)
# CHECK-NEXT:             Identifier(y)
# CHECK-NEXT:   VarDeclStatement(None)
# CHECK-NEXT:     Identifier(v)
# CHECK-NEXT:     FunctionLiteral(None)
# CHECK-NEXT:       BlockExpression
# CHECK-NEXT:         ReturnStatement
