# RUN: %belalang --emit=bir %s | %FileCheck %s

# CHECK: module {
# CHECK-NEXT: bir.func @main() {

# CHECK-NEXT: %[[C0:.*]] = bir.constant 1 : !bir.int
# CHECK-NEXT: %[[C1:.*]] = bir.var.declare "x" : <!bir.int>
# CHECK-NEXT: bir.var.store %[[C0]] to %[[C1]] : !bir.int to <!bir.int>

x := 1;

# CHECK-NEXT: %[[C2:.*]] = bir.constant 1.000000e+00 : !bir.float
# CHECK-NEXT: %[[C3:.*]] = bir.var.declare "y" : <!bir.float>
# CHECK-NEXT: bir.var.store %[[C2]] to %[[C3]] : !bir.float to <!bir.float>
y := 1.0;

# CHECK-NEXT: bir.return
# CHECK-NEXT: }
# CHECK-NEXT: }
