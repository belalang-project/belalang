# CHECK: Token { kind: Add, value: "", span: SourceSpan { start: 8, end: 9 } }
# CHECK: Token { kind: Literal { kind: Integer }, value: "2", span: SourceSpan { start: 10, end: 11 } }
# CHECK: Token { kind: RightParen, value: "", span: SourceSpan { start: 11, end: 12 } }
# CHECK: Token { kind: Semicolon, value: "", span: SourceSpan { start: 12, end: 13 } }
