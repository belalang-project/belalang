# RUN: %belalang build --emit=tokens %s | %FileCheck %s

=+(){}[],;!-/*5;5 < 10 > 5;:= >= <= += -= /= %= *= || &&

# CHECK: Token { kind: Assign { kind: Assign }, value: "", span: SourceSpan { start: 57, end: 58 } }
