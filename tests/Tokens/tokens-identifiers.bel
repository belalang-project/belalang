# RUN: %belalang build --emit=tokens %s | %FileCheck %s
# CHECK: Token { kind: Ident { sym: Symbol(2) }, span: SourceSpan { start: 0, end: 1 } }
# CHECK: Token { kind: Semicolon, span: SourceSpan { start: 1, end: 2 } }
# CHECK: Token { kind: Ident { sym: Symbol(2) }, span: SourceSpan { start: 3, end: 4 } }
# CHECK: Token { kind: Add, span: SourceSpan { start: 5, end: 6 } }
# CHECK: Token { kind: Ident { sym: Symbol(3) }, span: SourceSpan { start: 7, end: 8 } }
