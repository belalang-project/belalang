x; x + y

# RUN: %belalang build --emit=tokens %s | %FileCheck %s
# CHECK: Token { kind: Ident, value: "x", span: SourceSpan { start: 0, end: 1 } }
# CHECK: Token { kind: Semicolon, value: "", span: SourceSpan { start: 1, end: 2 } }
# CHECK: Token { kind: Ident, value: "x", span: SourceSpan { start: 3, end: 4 } }
# CHECK: Token { kind: Add, value: "", span: SourceSpan { start: 5, end: 6 } }
# CHECK: Token { kind: Ident, value: "y", span: SourceSpan { start: 7, end: 8 } }
