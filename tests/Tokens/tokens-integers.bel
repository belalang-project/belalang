# CHECK: Token { kind: Semicolon, value: "", span: SourceSpan { start: 8, end: 9 } }
# CHECK: Token { kind: Literal { kind: Integer }, value: "789", span: SourceSpan { start: 10, end: 13 } }
# CHECK: Token { kind: Add, value: "", span: SourceSpan { start: 14, end: 15 } }
# CHECK: Token { kind: Literal { kind: Integer }, value: "1", span: SourceSpan { start: 16, end: 17 } }
